DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/learnstack
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/learnstack_test

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=learnstack

OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Logging verbosity: DEBUG, INFO, WARNING, ERROR, or CRITICAL (default INFO if unset).
LOG_LEVEL=INFO

# HTTP Basic Auth — gates every route except /health. Single user, personal app.
BASIC_AUTH_USERNAME=your-username-here
BASIC_AUTH_PASSWORD=your-password-here
